{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "account-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/accounts/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "accounts/{**catch-all}" }
        ]
      },
      "transaction-route": {
        "ClusterId": "transaction-cluster",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "transactions/{**catch-all}" }
        ]
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/api/insights/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "insights/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-api:8080"
          }
        }
      },
      "account-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://account-api:8080"
          }
        }
      },
      "transaction-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://transaction-api:8080"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://ai-insights-api:8080"
          }
        }
      }
    }
  }
}
